# ============================================================
# SISTEMA DE CRONS - CONFIGURACIÓN POR SERVICIO
# ============================================================
# Cada servicio tiene su propia sección con un prefijo único
# Formato: [SERVICIO_]VARIABLE=valor

# ============================================================
# SERVICIO 1: NOTIFICADOR DE CUMPLEAÑOS
# ============================================================

# Habilitar/deshabilitar servicio
BIRTHDAY_ENABLED=true

# Base de datos MySQL (EXTERNA)
BIRTHDAY_DB_HOST=tu-servidor-mysql.com
BIRTHDAY_DB_PORT=3306
BIRTHDAY_DB_USER=tu_usuario
BIRTHDAY_DB_PASSWORD=tu_password
BIRTHDAY_DB_NAME=netos_law

# API de Notificaciones
BIRTHDAY_NOTIFICATIONS_API_URL=http://tu-servidor-api:8888
BIRTHDAY_BOT_ID=1
BIRTHDAY_CHAT_ID=123456789

# Horario de ejecución (opcional, por defecto 6:00 AM)
# Formato 24 horas (0-23 para horas, 0-59 para minutos)
# Ejemplos: 6 = 6:00 AM, 20 = 8:00 PM, 14 = 2:00 PM
BIRTHDAY_SCHEDULE_HOUR=6
BIRTHDAY_SCHEDULE_MINUTE=0

# ============================================================
# SERVICIO 2: OTRO SERVICIO (plantilla)
# ============================================================
# Descomentar y configurar cuando tengas otro servicio

# OTRO_ENABLED=true
# OTRO_CONFIG_VALUE=algo
# OTRO_SCHEDULE_HOUR=9
# OTRO_SCHEDULE_MINUTE=30

# ============================================================
# CONFIGURACIÓN GLOBAL
# ============================================================
TZ=America/Asuncion
